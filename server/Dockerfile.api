FROM node:20-bookworm

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends \
    python3 \
    python3-pip \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/*

COPY requirements-notebooklm.txt /tmp/requirements-notebooklm.txt

RUN if [ -f /tmp/requirements-notebooklm.txt ]; then \
      pip3 install --no-cache-dir -r /tmp/requirements-notebooklm.txt; \
    fi

ENV PYTHON_BIN=python3

CMD ["bash", "-lc", "npm install && node route-server.js"]